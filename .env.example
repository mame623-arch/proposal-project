# ─────────────────────────────────────────────────────────────
# Supabase (Project Settings > API) — 새 Supabase 프로젝트의 키
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ─────────────────────────────────────────────────────────────
# autoproposal 실행 연동 (pixt 서버의 pixt-runner)
#   - AUTOPROPOSAL_RUN_ENDPOINT: pixt-runner 의 베이스 URL (끝에 /run 붙이지 않음)
#       예) http://localhost:8787  또는  http://<pixt-host>:8787
#       라우트가 /run, /status/<id> 를 알아서 붙인다.
#   - AUTOPROPOSAL_RUN_TOKEN: pixt-runner 의 RUNNER_TOKEN 과 동일 값(설정했다면)
#   비어 있으면 실행 버튼은 "미설정" 안내만 표시한다(가이드/복사는 그대로 동작).
#   (pixt-runner 셋업은 pixt-runner/README.md 참고)
# ─────────────────────────────────────────────────────────────
AUTOPROPOSAL_RUN_ENDPOINT=
AUTOPROPOSAL_RUN_TOKEN=
