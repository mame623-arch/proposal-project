# pixt-runner 환경변수 (pixt 서버에서 export 하거나 .env 로 로드)

# 이 서버가 들을 포트
PORT=8787

# 바인딩 주소. 기본 127.0.0.1 = localhost 전용(외부 네트워크 차단, 권장).
# 다른 머신에서 호출해야 할 때만 0.0.0.0 으로 (그땐 RUNNER_TOKEN 필수).
HOST=127.0.0.1

# 설정하면 /run, /status 요청에 Authorization: Bearer <RUNNER_TOKEN> 필수.
# 웹앱(.env.local)의 AUTOPROPOSAL_RUN_TOKEN 과 같은 값으로 맞춘다.
RUNNER_TOKEN=

# claude 가 돌 작업 폴더 (autoproposal 스킬 폴더의 절대경로) — 필수
AUTOPROPOSAL_DIR=/home/damilab/haneul/autoproposal

# claude 실행 파일 (PATH 에 없으면 절대경로로)
CLAUDE_BIN=claude

# 모델 / 자동 실행 옵션
MODEL=claude-opus-4-8
ALLOWED_TOOLS=Read,Edit,Write,Bash
PERMISSION_MODE=acceptEdits

# 한 작업 최대 시간 (ms)
JOB_TIMEOUT_MS=1800000

# 인증 키 (claude CLI 가 자체 로그인돼 있지 않으면 필요)
# ANTHROPIC_API_KEY=sk-ant-...
